$TTL    604800
@       IN      SOA     ocpsec-svc.ocp.lan. contact.ocp.lan (
                  1     ; Serial
             604800     ; Refresh
              86400     ; Retry
            2419200     ; Expire
             604800     ; Minimum
)
        IN      NS      ocpsec-svc

ocpsec-svc.ocp.lan.          IN      A       172.16.16.198

; Temp Bootstrap Node
ocp-bootstrap.lab.ocp.lan.        IN      A      172.16.18.90

; Control Plane Nodes
ocp-cp-1.lab.ocp.lan.         IN      A      172.16.18.91
ocp-cp-2.lab.ocp.lan.         IN      A      172.16.18.92
ocp-cp-3.lab.ocp.lan.         IN      A      172.16.18.93

; Worker Nodes
ocp-w-1.lab.ocp.lan.        IN      A      172.16.18.94
ocp-w-2.lab.ocp.lan.        IN      A      172.16.18.95

; OpenShift Internal - Load balancer
api.lab.ocp.lan.        IN    A    172.16.16.198
api-int.lab.ocp.lan.    IN    A    172.16.16.198
*.apps.lab.ocp.lan.     IN    A    172.16.16.198

; ETCD Cluster
etcd-0.lab.ocp.lan.    IN    A     172.16.18.91
etcd-1.lab.ocp.lan.    IN    A     172.16.18.91
etcd-2.lab.ocp.lan.    IN    A     172.16.18.91

; OpenShift Internal SRV records (cluster name = lab)
_etcd-server-ssl._tcp.lab.ocp.lan.    86400     IN    SRV     0    10    2380    etcd-0.lab
_etcd-server-ssl._tcp.lab.ocp.lan.    86400     IN    SRV     0    10    2380    etcd-1.lab
_etcd-server-ssl._tcp.lab.ocp.lan.    86400     IN    SRV     0    10    2380    etcd-2.lab

oauth-openshift.apps.lab.ocp.lan.     IN     A     172.16.16.198
console-openshift-console.apps.lab.ocp.lan.     IN     A     172.16.16.198
